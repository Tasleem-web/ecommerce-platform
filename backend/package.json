{
    "name": "express-gen-ts",
    "version": "0.0.0",
    "scripts": {
        "clean-install": "rm -rf ./node_modules && rm -r package-lock.json && npm i",
        "dev:user-service": "cross-env DOTENV_CONFIG_PATH=./config/.env.development nodemon --watch microservices --ext ts --exec \"ts-node ./microservices/user-service/src/index.ts\"",
        "dev:product-service": "cross-env DOTENV_CONFIG_PATH=./config/.env.development nodemon --watch microservices --ext ts --exec \"ts-node ./microservices/product-service/src/index.ts\"",
        "dev:profile-service": "cross-env DOTENV_CONFIG_PATH=./config/.env.development nodemon --watch microservices --ext ts --exec \"ts-node ./microservices/profile-service/src/index.ts\"",
        "dev:microservices": "concurrently -n user,product -c blue,green \"npm:dev:user-service\" \"npm:dev:product-service\"",
        "lint": "eslint .",
        "format": "prettier --write .",
        "type-check": "tsc -b --noEmit"
    },
    "engines": {
        "node": ">=16.0.0"
    },
    "dependencies": {
        "@types/express-session": "^1.19.0",
        "bcrypt": "^6.0.0",
        "cloudinary": "^2.10.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "cross-env": "^10.1.0",
        "dayjs": "^1.11.21",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^7.4.1",
        "express-session": "^1.19.0",
        "helmet": "^8.2.0",
        "http-proxy-middleware": "^3.0.3",
        "ioredis": "^5.4.1",
        "jet-env": "^1.1.6",
        "jet-logger": "^2.2.3",
        "jet-paths": "^3.1.1",
        "jet-validators": "^2.3.1",
        "joi": "^17.13.3",
        "js-yaml": "^4.2.0",
        "jsonfile": "^6.2.1",
        "jsonwebtoken": "^9.0.2",
        "kafkajs": "^2.2.2",
        "module-alias": "^2.3.4",
        "morgan": "^1.11.0",
        "mysql": "^2.18.1",
        "mysql2": "^3.11.3",
        "sequelize": "^6.37.8",
        "swagger-ui-express": "^5.0.1",
        "tspo": "^1.0.7",
        "winston": "^3.15.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@swc/core": "^1.15.41",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/bcrypt": "^5.0.2",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/find": "^0.2.4",
        "@types/fs-extra": "^11.0.4",
        "@types/jest": "^29.5.13",
        "@types/js-yaml": "^4.0.9",
        "@types/jsonfile": "^6.1.4",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/module-alias": "^2.0.4",
        "@types/morgan": "^1.9.10",
        "@types/node": "^26.0.0",
        "@types/supertest": "^7.2.0",
        "@types/swagger-ui-express": "^4.1.6",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "browser-sync": "^3.0.4",
        "concurrently": "^10.0.3",
        "delay-cli": "^3.0.0",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-n": "^18.1.0",
        "find": "^0.3.0",
        "fs-extra": "^11.3.5",
        "jest": "^25.0.0",
        "jiti": "^2.7.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.4",
        "shx": "^0.4.0",
        "supertest": "^7.2.2",
        "ts-jest": "^27.0.3",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1",
        "vitest": "^4.1.9"
    }
}
