{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useUnknownInCatchVariables": false
  },
  "ts-node": {
    "swc": true,
    "require": ["dotenv/config"],
  },
  "include": [
    "microservices/**/*.ts",
    "eslint.config.ts"
  ]
}
